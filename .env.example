# Vite dev/preview only: proxy target for /api, /setting, /dashboard, /alert, /ws (see frontend/vite.config.js).
# Local: 127.0.0.1 + BACKEND_PORT / WEBSOCKET_PORT. Production-style: https://api.example.com (no :port; paths stay /setting, /ws).
SERVER_IP=127.0.0.1
# Optional: use http:// and ws:// for non-local SERVER_IP (1/true/yes)
# VITE_BACKEND_USE_HTTP=1

# Frontend (Vite): bind address (127.0.0.1 avoids some VPN/tunnel issues; use 0.0.0.0 to allow LAN)
# VITE_DEV_HOST=127.0.0.1
# VITE_FRONTEND_PORT=5173
# Split API host at build time (leave unset for same-origin + dev proxy)
# VITE_API_ORIGIN=

BACKEND_PORT=4000
WEBSOCKET_PORT=4001
CTHREAD_COUNT=8
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sportbet
DB_USER=postgres
DB_PASSWORD=postgres

# When true (1/yes/on), dashboard and WebSocket compared odds are not limited to the last 10 minutes.
DISABLE_ODDS_10M_DEADLINE=false
