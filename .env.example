# When true (1/yes/on), dashboard and WebSocket compared odds are not limited to the last 10 minutes.
DISABLE_ODDS_10M_DEADLINE=false

# Stake.com → Settings → Security → API Tokens (extension posts GraphQL from the Stake tab; token is optional but recommended)
STAKE_ACCESS_TOKEN=
