SERVER_IP=127.0.0.1

# Frontend (Vite): bind address (127.0.0.1 avoids some VPN/tunnel issues; use 0.0.0.0 to allow LAN)
# VITE_DEV_HOST=127.0.0.1
# VITE_FRONTEND_PORT=5173
# Split API host at build time (leave unset for same-origin + dev proxy)
# VITE_API_ORIGIN=

BACKEND_PORT=4000
WEBSOCKET_PORT=4001
CTHREAD_COUNT=8
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sportbet
DB_USER=postgres
DB_PASSWORD=postgres

# When true (1/yes/on), dashboard and WebSocket compared odds are not limited to the last 10 minutes.
DISABLE_ODDS_10M_DEADLINE=false

# Stake Odds Data API (https://docs-odds-data.stake.com/) — optional fallback if key is not saved in Settings UI
STAKE_ODDS_API_KEY=
# Optional overrides (defaults shown on https://odds-data.stake.com/)
# STAKE_ODDS_DATA_BASE=https://odds-data.stake.com
# STAKE_ODDS_FIXTURES_PATH=/sports/basketball/usa/nba/fixtures
# STAKE_ODDS_POLL_INTERVAL_MS=60000
